# Copie para .env e preencha. NUNCA commite o .env (está no .gitignore).

# App
APP_ENV=development
APP_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Banco — Supabase Postgres (use o "Session pooler" URI: Project > Connect)
# Formato: postgresql+psycopg://postgres.<ref>:<senha>@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase (valores PÚBLICOS — seguros no cliente)
SUPABASE_URL=https://hbderqkuebemcqyakoln.supabase.co
SUPABASE_ANON_KEY=sb_publishable_yvVnStAoS0MDnMyfGZwpZw_R7ZzEhOr
# SEGREDO — somente backend. Nunca expor ao frontend (sem NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# LLM (Anthropic) — usado a partir do Estágio 1B
ANTHROPIC_API_KEY=

# Observabilidade (Langfuse) — opcional; cliente vira no-op se em branco
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
