# Copie para .env e preencha. NUNCA commite o .env (está no .gitignore).

# App
APP_ENV=development
APP_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Banco — Supabase Postgres (projeto tese-ai). Copie o "Session pooler" URI EXATO
# em: Project > Connect > Session pooler (traz o host correto + a sua senha do banco).
# Formato: postgresql+psycopg://postgres.rjpqaaymwhcwxtinppvc:<SENHA-DO-BANCO>@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase (valores PÚBLICOS — seguros no cliente; protegidos por RLS)
SUPABASE_URL=https://rjpqaaymwhcwxtinppvc.supabase.co
SUPABASE_ANON_KEY=sb_publishable_nruI7x_X2RDmBHRjzobCrA_R15FV_EC
# SEGREDO — somente backend. Nunca expor ao frontend (sem NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# LLM (Anthropic) — usado a partir do Estágio 1B
ANTHROPIC_API_KEY=

# Observabilidade (Langfuse) — opcional; cliente vira no-op se em branco
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Rate-limit distribuído — opcional. Com REDIS_URL o slowapi usa Redis como
# storage (bucket compartilhado entre instâncias/workers); em branco, memória do
# processo. Produção: prefira rediss:// (TLS). Ex.: rediss://default:<senha>@host:6380/0
REDIS_URL=

# Scheduler in-app (jobs de manutenção; cadência por ledger job_runs no banco).
# SCHEDULER_ENABLED=false desliga tudo; intervalo 0 desliga o job individual.
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=60
SCHEDULER_REAPER_MIN=15
SCHEDULER_MACRO_HORAS=24
SCHEDULER_CADASTRO_HORAS=168

# Conectores premium behind-config (opcionais; keyless segue sem eles)
FRED_API_KEY=
EIA_API_KEY=

# Qualidade de dados: idade máxima (meses) de fundamento de par SEC como "atual"
PARES_MAX_IDADE_MESES=24
